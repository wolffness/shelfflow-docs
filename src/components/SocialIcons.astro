---
import Default from '@astrojs/starlight/components/SocialIcons.astro';
---

<Default {...Astro.props} />
<a
  href="https://shelfflow.com.br"
  target="_blank"
  rel="noopener noreferrer"
  class="sl-cta-btn"
>
  Comecar gratis
  <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7M7 7h10v10"/></svg>
</a>

<style>
  .sl-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #fff;
    background: var(--sl-color-accent);
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s ease;
  }

  .sl-cta-btn:hover {
    background: var(--sl-color-accent-high);
  }
</style>
